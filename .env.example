# LLM 키 (코어 모듈 + 채팅 백엔드 공용)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001

# 백엔드 CORS 허용 도메인 (쉼표 구분)
# 개발: 비워두면 http://localhost:5173 디폴트
# 운영 예시: https://fincoach.example.com,https://fincoach.pages.dev
ALLOWED_ORIGINS=

# 로깅
LOG_LEVEL=INFO

# web/ (Vite) 빌드 시점 환경변수
# 개발: 비워두면 vite proxy로 /api → localhost:8000
# 운영: https://api.fincoach.example.com 같은 백엔드 origin
VITE_API_BASE=

# GitHub Actions secrets (저장소 Settings > Secrets에 등록)
# CLOUDFLARE_API_TOKEN=...      # Pages 배포 권한
# CLOUDFLARE_ACCOUNT_ID=...     # 계정 ID
